[Unit]
Description=Rclone Mount T7 WebDAV
After=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/rclone mount T7-allen-r: %h/mnt/T7-allen \
    --config %h/.config/rclone/rclone.conf \
    --vfs-cache-mode full \
    --vfs-cache-max-age 24h \
    --vfs-read-chunk-size 128M
ExecStop=/usr/bin/fusermount -u %h/mnt/T7-allen
Restart=on-failure

[Install]
WantedBy=default.target
