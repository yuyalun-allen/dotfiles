[user]
	name = allen
	email = yuyalun.allen@gmail.com
[core]
	excludesfile = /home/allen/.config/git/gitignore_global
	editor = vim
#  pager = delta
	ignorecase = false
	quotepath = false
[push]
	default = current
[init]
	defaultBranch = master
[credential]
	helper = store
[merge]
  conflictstyle = zdiff3
	tool = vimdiff
[pull]
	rebase = true
# 
# [interactive]
#   diffFilter = delta --color-only
# [delta]
#   navigate = true    # use n and N to move between diff sections
[alias]
	co = checkout
	br = branch
	ci = commit
	st = status
[color]
	ui = auto
